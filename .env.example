# ============================================================
# WorkNest — Environment Variables
# Copy this file to apps/api/.env and apps/web/.env.local
# and fill in real values before running
# ============================================================

# ---- API (apps/api/.env) ----

# PostgreSQL connection string
# Railway provides this automatically as ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:password@localhost:5432/worknest"

# JWT Secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="change-me-to-a-random-32-char-secret"
JWT_REFRESH_SECRET="change-me-to-a-different-32-char-secret"

# Token expiry
JWT_ACCESS_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS — URL of the frontend app
CLIENT_URL="http://localhost:3000"

# Cloudinary (https://cloudinary.com — free tier)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Resend (https://resend.com — free tier, 3000 emails/month)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="WorkNest <noreply@yourdomain.com>"


# ---- Web (apps/web/.env.local) ----

# Public API base URL (used by browser Axios client)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Socket.io server URL (usually same as API)
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# JWT secret must match apps/api JWT_ACCESS_SECRET (used only in middleware)
JWT_ACCESS_SECRET="change-me-to-a-random-32-char-secret"


# ============================================================
# Railway Deployment Notes
# ============================================================
# 1. Create two services in Railway: "api" and "web"
# 2. For "api": add a PostgreSQL plugin — DATABASE_URL is auto-injected
# 3. Set all env vars above in each service's Variables tab
# 4. API start command: npx prisma migrate deploy && node dist/index.js
# 5. Web start command: node server.js  (Next.js standalone)
# 6. Set CLIENT_URL in api to your Railway web service URL
# 7. Set NEXT_PUBLIC_API_URL in web to your Railway api service URL
