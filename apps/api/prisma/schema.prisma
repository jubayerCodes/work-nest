// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  MEMBER
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  AT_RISK
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActionStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

// ============================================================
// USER
// ============================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  avatarUrl      String?
  avatarPublicId String?
  refreshToken   String? // stored as bcrypt hash
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships   WorkspaceMember[]
  ownedGoals    Goal[]
  assignedItems ActionItem[]   @relation("Assignee")
  notifications Notification[]
  reactions     Reaction[]
  comments      Comment[]
  mentionedIn   Mention[]
  activities    Activity[]
  preferences   UserPreference?
}

// ============================================================
// WORKSPACE
// ============================================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  accentColor String   @default("#6366f1")
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       WorkspaceMember[]
  goals         Goal[]
  announcements Announcement[]
  actionItems   ActionItem[]
  invitations   Invitation[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())
  userId      String
  workspaceId String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Invitation {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique
  expiresAt   DateTime
  accepted    Boolean  @default(false)
  workspaceId String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ============================================================
// GOAL & MILESTONE
// ============================================================

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text // rich text HTML from Tiptap
  status      GoalStatus @default(NOT_STARTED)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  ownerId     String
  workspaceId String

  owner       User         @relation(fields: [ownerId], references: [id])
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  actionItems ActionItem[]
  activities  Activity[]
}

model Milestone {
  id        String    @id @default(cuid())
  title     String
  completed Boolean   @default(false)
  dueDate   DateTime?
  goalId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ============================================================
// ANNOUNCEMENT, REACTION, COMMENT, MENTION
// ============================================================

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text // rich text HTML from Tiptap
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  workspaceId String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  comments  Comment[]
}

model Reaction {
  id             String @id @default(cuid())
  emoji          String
  userId         String
  announcementId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId, emoji])
}

model Comment {
  id             String   @id @default(cuid())
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  authorId       String
  announcementId String
  parentId       String? // null = top-level, set = reply

  author       User         @relation(fields: [authorId], references: [id])
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  parent       Comment?     @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies      Comment[]    @relation("Replies")
  mentions     Mention[]
}

model Mention {
  id        String @id @default(cuid())
  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// ============================================================
// ACTION ITEM
// ============================================================

model ActionItem {
  id          String       @id @default(cuid())
  title       String
  priority    Priority     @default(MEDIUM)
  status      ActionStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assigneeId  String?
  workspaceId String
  goalId      String?

  assignee  User?      @relation("Assignee", fields: [assigneeId], references: [id])
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  goal      Goal?      @relation(fields: [goalId], references: [id])
}

// ============================================================
// ACTIVITY FEED
// ============================================================

model Activity {
  id        String   @id @default(cuid())
  type      String // e.g. "GOAL_STATUS_CHANGED", "MILESTONE_COMPLETED", "MEMBER_JOINED"
  payload   Json
  createdAt DateTime @default(now())
  actorId   String
  goalId    String?

  actor User  @relation(fields: [actorId], references: [id])
  goal  Goal? @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  type      String // e.g. "MENTION", "GOAL_UPDATE", "ANNOUNCEMENT"
  payload   Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// USER PREFERENCES
// ============================================================

model UserPreference {
  id             String  @id @default(cuid())
  userId         String  @unique
  actionItemView String  @default("kanban") // "kanban" | "list"
  lastWorkspaceId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
